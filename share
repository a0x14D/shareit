                    </div>
                </div>

                <div>
                    <label style="font-size: 10px; font-weight: bold; color: var(--text-muted); display: block; margin-bottom: 4px;">SHA-256 HASH</label>
                    <input id="hash-input" type="text" class="input-text" placeholder="String..." oninput="generateHash()">
                    <div id="hash-output" style="background: rgba(0,0,0,0.5); padding: 8px; border-radius: 4px; font-family: monospace; font-size: 11px; color: var(--success); margin-top: 8px; word-break: break-all;">Awaiting input...</div>
                </div>
                
                <div>
                    <label style="font-size: 10px; font-weight: bold; color: var(--text-muted); display: block; margin-bottom: 4px;">PASSWORD GENERATOR</label>
                    <div class="flex-row">
                        <input id="pwd-output" type="text" class="input-text flex-1" readonly>
                        <button onclick="genPwd()" class="btn">Generate</button>
                    </div>
                </div>
                
                <div>
                    <label style="font-size: 10px; font-weight: bold; color: var(--text-muted); display: block; margin-bottom: 4px;">JSON FORMATTER</label>
                    <textarea id="json-input" class="textarea" style="min-height: 60px; margin-bottom: 8px;" placeholder='{"key":"value"}'></textarea>
                    <div class="flex-row">
                        <button onclick="formatJson(true)" class="btn flex-1">Pretty Print</button>
                        <button onclick="formatJson(false)" class="btn flex-1">Minify</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function val(id, setVal) {
            if (setVal !== undefined) document.getElementById(id).value = setVal;
            return document.getElementById(id).value;
        }

        async function generateHash() {
            const input = val('hash-input');
            if(!input) { document.getElementById('hash-output').innerText = 'Awaiting input...'; return; }
            const msgBuffer = new TextEncoder().encode(input);
            const hashBuffer = await crypto.subtle.digest('SHA-256', msgBuffer);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            document.getElementById('hash-output').innerText = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
        }
        
        function genPwd() {
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+~`|}{[]:;?><,./-=";
            let pwd = "";
            const array = new Uint32Array(16);
            window.crypto.getRandomValues(array);
            for (let i = 0; i < 16; i++) { pwd += chars[array[i] % chars.length]; }
            val('pwd-output', pwd);
        }
        
        function formatJson(pretty) {
            try {
                const obj = JSON.parse(val('json-input'));
                val('json-input', JSON.stringify(obj, null, pretty ? 4 : 0));
            } catch(e) { alert("Invalid JSON"); }
        }

        async function fetchChat() {
            try {
                const res = await fetch('/api/chat');
                const chat = await res.json();
                let html = '';
                for (const msg of chat) {
                    html += `<div class="chat-msg">
                        <div class="chat-header">
                            <span style="color: ${msg.ip === '127.0.0.1' ? 'var(--danger)' : 'var(--accent)'}">${msg.ip}</span>
                            <span style="color: var(--text-muted)">${msg.time}</span>
                        </div>
                        <div style="font-family: monospace; word-break: break-word;">${msg.msg}</div>
                    </div>`;
                }
                const box = document.getElementById('chatBox');
                const isScrolledToBottom = box.scrollHeight - box.clientHeight <= box.scrollTop + 1;
                box.innerHTML = html;
                if (isScrolledToBottom) box.scrollTop = box.scrollHeight;
            } catch (e) {}
        }
        
        async function sendChat(e) {
            e.preventDefault();
            const msg = val('chatInput');
            if(!msg) return;
            val('chatInput', '');
            await fetch('/tools/chat/api', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'msg=' + encodeURIComponent(msg)
            });
            fetchChat();
        }

        fetchChat();
        setInterval(fetchChat, 2000);
    </script>
</body>
</html>
"""

