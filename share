        document.addEventListener('keydown', e => {
            if (e.ctrlKey && e.key === 'k') { e.preventDefault(); searchInput.focus(); }
            if (e.key === 'Escape') { 
                document.getElementById('qr-modal').style.display='none';
                searchInput.blur();
