def resolve_safe_path(filename):
    file_path = os.path.realpath(os.path.join(RECORDINGS_DIR, filename))
    if not file_path.startswith(os.path.realpath(RECORDINGS_DIR)): abort(403)
    if not os.path.exists(file_path): abort(404)
    return file_path

@app.route('/preview/<path:filename>')
def preview_file(filename):
    file_path = resolve_safe_path(filename)
    
    if filename.endswith(".enc"):
        with open(file_path, "rb") as f: decrypted_data = cipher_suite.decrypt(f.read())
        original_name = filename[:-4]
        
        if original_name.endswith('.md'):
            return render_markdown_preview(decrypted_data.decode('utf-8', errors='ignore'), original_name)
        elif original_name.endswith(('.py', '.sh', '.txt', '.js', '.json', '.html')):
            return render_code_preview(decrypted_data.decode('utf-8', errors='ignore'), original_name)
            
        mime_type, _ = mimetypes.guess_type(original_name)
        return send_file(io.BytesIO(decrypted_data), mimetype=mime_type or 'application/octet-stream', as_attachment=False, download_name=original_name)
    
    if filename.endswith('.md'):
        with open(file_path, "r", encoding='utf-8', errors='ignore') as f: return render_markdown_preview(f.read(), filename)
    elif filename.endswith(('.py', '.sh', '.txt', '.js', '.json', '.html')):
        with open(file_path, "r", encoding='utf-8', errors='ignore') as f: return render_code_preview(f.read(), filename)

    mime_type, _ = mimetypes.guess_type(filename)
    if mime_type and (mime_type.startswith('image/') or mime_type.startswith('video/') or mime_type.startswith('audio/')):
        return render_media_preview(os.path.basename(filename), filename)

    return send_file(file_path, mimetype=mime_type, as_attachment=False)

