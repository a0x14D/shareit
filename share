def render_media_preview(filename, path):
    mime_type, _ = mimetypes.guess_type(filename)
    url_path = urllib.parse.quote(path)
    media_html = ""
    if mime_type and mime_type.startswith('image/'):
        media_html = f'<img src="/download/{url_path}" style="max-width:100%; max-height:80vh; border-radius:8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);">'
    elif mime_type and mime_type.startswith('video/'):
        media_html = f'<video src="/download/{url_path}" controls autoplay style="max-width:100%; max-height:80vh; border-radius:8px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); outline:none;"></video>'
    elif mime_type and mime_type.startswith('audio/'):
        media_html = f'<audio src="/download/{url_path}" controls autoplay style="width:100%; max-width:400px; outline:none;"></audio>'
    
    return f"""
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
